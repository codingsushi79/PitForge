DATABASE_URL=postgresql://...   # Neon Postgres (production / Vercel)

JWT_SECRET=your-secret-here

# Cloudflare R2 (setup file uploads)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=pitforge-setups

# Public bucket URL (R2 custom domain)
R2_PUBLIC_URL=https://pitforge-setupsr2url.sushii.dev
